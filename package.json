{
  "name": "obsidian-local-gpt",
  "version": "4.2.2",
  "description": "Local GPT assistance for maximum privacy and offline access",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "typecheck": "tsc --noEmit && svelte-check --tsconfig tsconfig.json",
    "build": "npm run typecheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "format": "prettier 'styles.css' 'src/**/*.{ts,json}' --write",
    "lint": "eslint --ext .ts src tests",
    "test": "vitest run --coverage",
    "check": "npm run lint && npm run typecheck && npm run test",
    "full-check": "npm run format && npm run build && npm run test",
    "prepare": "npx simple-git-hooks"
  },
  "keywords": [
    "obsidian",
    "ollama",
    "ai",
    "plugin",
    "llm",
    "gpt"
  ],
  "author": "Pavel Frankov",
  "license": "MIT",
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/aria-query": "^5.0.4",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.1.2",
    "builtin-modules": "^5.0.0",
    "esbuild": "^0.27.7",
    "esbuild-plugin-inline-worker": "^0.1.1",
    "esbuild-svelte": "^0.9.4",
    "eslint-plugin-sonarjs": "^4.0.2",
    "jsdom": "^29.0.1",
    "obsidian": "^1.12.3",
    "prettier": "^3.8.1",
    "simple-git-hooks": "^2.11.0",
    "svelte": "^5.55.1",
    "svelte-check": "^4.4.6",
    "svelte-preprocess": "^6.0.3",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@obsidian-ai-providers/sdk": "^1.7.0",
    "idb": "^8.0.3",
    "pdfjs-dist": "^5.6.205",
    "sortablejs": "^1.15.7"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run format"
  }
}
